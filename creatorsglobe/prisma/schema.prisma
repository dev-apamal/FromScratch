generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CreatorRoleType {
  DIRECTOR
  CINEMATOGRAPHER
  EDITOR
  PHOTOGRAPHER
  PRODUCER
  WRITER
  SOUND_DESIGNER
  COLORIST
  ANIMATOR
  MAKEUP_ARTIST
  STYLIST
  OTHER
}

enum AvailabilityType {
  AVAILABLE
  UNAVAILABLE
  TENTATIVE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?
  phone          String?
  creatorProfile CreatorProfile?
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CreatorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  headline           String?
  bio                String?
  experienceLevel    ExperienceLevel
  budgetMin          Int?
  budgetMax          Int?
  budgetCurrency     String             @default("USD")
  latitude           Decimal            @db.Decimal(9, 6)
  longitude          Decimal            @db.Decimal(9, 6)
  city               String?
  state              String?
  country            String?
  availabilityStatus AvailabilityType   @default(AVAILABLE)
  isAvailableForHire Boolean            @default(true)
  travelRadiusKm     Int?
  websiteUrl         String?
  instagramUrl       String?
  linkedinUrl        String?
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles              CreatorRole[]
  portfolioItems     PortfolioItem[]
  availabilitySlots  AvailabilitySlot[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([city])
  @@index([country])
  @@index([experienceLevel])
  @@index([budgetMin, budgetMax])
  @@index([latitude, longitude])
}

model CreatorRole {
  id               String          @id @default(cuid())
  creatorProfileId String
  role             CreatorRoleType
  creatorProfile   CreatorProfile  @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())

  @@unique([creatorProfileId, role])
  @@index([role])
}

model PortfolioItem {
  id               String          @id @default(cuid())
  creatorProfileId String
  title            String
  description      String?
  mediaUrl         String
  thumbnailUrl     String?
  projectUrl       String?
  roleLabel        String?
  completedAt      DateTime?
  sortOrder        Int             @default(0)
  creatorProfile   CreatorProfile  @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([creatorProfileId, sortOrder])
}

model AvailabilitySlot {
  id               String           @id @default(cuid())
  creatorProfileId String
  weekday          Weekday
  startTime        String
  endTime          String
  type             AvailabilityType @default(AVAILABLE)
  timezone         String           @default("UTC")
  creatorProfile   CreatorProfile   @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([creatorProfileId, weekday])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
